# ATA Protocol — Standalone (no OpenClaw required)

# Server Identity
ATA_AGENT_ID=agent://your-name/assistant
ATA_AGENT_NAME=Assistant
ATA_AGENT_OWNER=your-name
ATA_AGENT_VERSION=0.1.0

# Capabilities this agent exposes (comma-separated)
ATA_CAPABILITIES=ping,echo

# Server settings
ATA_PORT=3740
ATA_HOST=0.0.0.0

# Public-facing URL (use ngrok/Cloudflare Tunnel for production)
ATA_PUBLIC_URL=http://localhost:3740

# HMAC shared secret — must match between sender and receiver
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ATA_SHARED_SECRET=change-this-to-a-random-secret

# Task state storage
ATA_DATA_DIR=./data

# Task expiry (default: 24h)
ATA_TASK_TTL_MS=86400000

# Client polling settings
ATA_POLL_TIMEOUT_MS=30000
ATA_POLL_INTERVAL_MS=1000
