# ATA Protocol Configuration

# Your agent identity
ATA_AGENT_ID=agent://your-username/main
ATA_AGENT_NAME=My Agent
ATA_OWNER=your-username

# Server settings
ATA_PORT=3740
ATA_PUBLIC_URL=https://your-domain.com

# Security: shared HMAC secret (must match between sender and receiver)
ATA_SHARED_SECRET=change-this-to-a-random-secret

# Your agent capabilities (comma-separated)
ATA_CAPABILITIES=ping,review_tweet,fb_dm

# OpenClaw gateway (for forwarding received tasks to local agent)
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token
OPENCLAW_AGENT_ID=main
